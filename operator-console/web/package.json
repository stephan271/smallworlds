{
  "name": "smallworlds-operator-console-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "generate:api": "openapi-typescript ../api/openapi.json -o src/lib/generated/api.ts",
    "test:e2e": "playwright test",
    "test:e2e:local-bootstrap": "playwright test --config local-bootstrap.playwright.config.ts",
    "test:e2e:real-node": "playwright test --config real-node.playwright.config.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.70.1",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "openapi-typescript": "7.13.0",
    "svelte": "5.56.6",
    "svelte-check": "4.7.3",
    "typescript": "5.9.3",
    "vite": "8.1.5"
  }
}
