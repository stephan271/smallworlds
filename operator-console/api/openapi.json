{
  "openapi": "3.1.0",
  "info": {
    "title": "SmallWorlds Bootstrap Launcher API",
    "version": "0.1.0"
  },
  "servers": [{ "url": "/" }],
  "security": [{ "launcherSession": [] }],
  "paths": {
    "/api/v1/session": {
      "get": {
        "operationId": "getSession",
        "responses": {
          "200": {
            "description": "Authenticated launcher session",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Session" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/session/exchange": {
      "post": {
        "operationId": "exchangeSession",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SessionExchange" } } }
        },
        "responses": {
          "200": {
            "description": "Session established",
            "headers": { "Set-Cookie": { "schema": { "type": "string" } } },
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Session" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/vault": {
      "get": {
        "operationId": "getVaultStatus",
        "responses": {
          "200": {
            "description": "Launcher Vault status and available unlock facilities",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VaultStatus" } } }
          }
        }
      }
    },
    "/api/v1/vault/unlock": {
      "post": {
        "operationId": "unlockVault",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VaultUnlockInput" } } }
        },
        "responses": {
          "200": {
            "description": "Unlocked Launcher Vault",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/VaultStatus" } } }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "503": { "$ref": "#/components/responses/Unavailable" }
        }
      }
    },
    "/api/v1/recovery-bundles/export": {
      "post": {
        "operationId": "exportRecoveryBundle",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryBundleExportInput" } } }
        },
        "responses": {
          "200": { "description": "Encrypted portable recovery bundle", "content": { "application/octet-stream": { "schema": { "type": "string", "format": "binary" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "423": { "$ref": "#/components/responses/Locked" }
        }
      }
    },
    "/api/v1/recovery-bundles/preview": {
      "post": {
        "operationId": "previewRecoveryBundle",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryBundleOpenInput" } } }
        },
        "responses": {
          "200": { "description": "Safe source identity, without protected material", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryBundlePreview" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/recovery-bundles/import": {
      "post": {
        "operationId": "importRecoveryBundle",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryBundleImportInput" } } }
        },
        "responses": {
          "201": { "description": "Lifecycle authority transferred after explicit confirmation", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RecoveryBundleImportResult" } } } },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "409": { "$ref": "#/components/responses/Conflict" },
          "423": { "$ref": "#/components/responses/Locked" }
        }
      }
    },
    "/api/v1/capabilities": {
      "get": {
        "operationId": "getCapabilityCatalog",
        "responses": { "200": { "description": "Versioned capability catalog", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CapabilityCatalog" } } } } }
      }
    },
    "/api/v1/capabilities/plan": {
      "post": {
        "operationId": "planCapabilitySelection",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CapabilityPlanInput" } } } },
        "responses": { "201": { "description": "Reviewed deterministic GitOps Overlay change plan", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CapabilityPlanResult" } } } }, "400": { "$ref": "#/components/responses/BadRequest" } }
      }
    },
    "/api/v1/github/token/validate": {
      "post": {
        "operationId": "validateGitHubToken",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GitHubTokenInput" } } } },
        "responses": { "200": { "description": "Validated token metadata without token value", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GitHubTokenStatus" } } } }, "403": { "$ref": "#/components/responses/Conflict" }, "423": { "$ref": "#/components/responses/Locked" } }
      }
    },
    "/api/v1/github/overlay/establish": {
      "post": {
        "operationId": "establishGitHubOverlay",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GitHubOverlayEstablishInput" } } } },
        "responses": { "201": { "description": "Private overlay initialized from an approved plan", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OverlayIdentity" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/generic-git/token/validate": {
      "post": {
        "operationId": "validateGenericGitCredentials",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericGitCredentialInput" } } } },
        "responses": { "200": { "description": "Validated, write-only generic Git credentials", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericGitCredentialStatus" } } } }, "403": { "$ref": "#/components/responses/Conflict" }, "423": { "$ref": "#/components/responses/Locked" } }
      }
    },
    "/api/v1/generic-git/overlay/establish": {
      "post": {
        "operationId": "establishGenericGitOverlay",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericGitOverlayEstablishInput" } } } },
        "responses": { "201": { "description": "Existing empty HTTPS repository initialized from its exact approved plan", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OverlayIdentity" } } } }, "200": { "description": "Previously recorded remote commit verified; no duplicate push", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OverlayIdentity" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/generic-git/overlay/propose": {
      "post": {
        "operationId": "proposeGenericGitOverlay",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericGitOverlayEstablishInput" } } } },
        "responses": { "201": { "description": "Exact reviewed change pushed to a named branch; merge it manually in the chosen provider", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GenericGitProposal" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/bootstrap-assets": {
      "get": {
        "operationId": "getBootstrapAssetRequirements",
        "parameters": [{ "name": "release", "in": "query", "required": true, "schema": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+" } }],
        "responses": { "200": { "description": "Safe release-pinned bootstrap asset requirements and cache state", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BootstrapAssetRequirements" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/bootstrap-assets/acquire": {
      "post": {
        "operationId": "acquireBootstrapAssets",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BootstrapAssetAcquireInput" } } } },
        "responses": { "201": { "description": "Catalogued signed assets acquired into private cache", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BootstrapAssetRequirements" } } } }, "409": { "$ref": "#/components/responses/Conflict" }, "502": { "$ref": "#/components/responses/Unavailable" } }
      }
    },
    "/api/v1/nodes/probe": {
      "post": {
        "operationId": "probeNodeHostKey",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeProbeInput" } } } },
        "responses": { "200": { "description": "Untrusted first-contact SSH fingerprint for explicit confirmation", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeProbeResult" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/nodes/capabilities": {
      "get": {
        "operationId": "getNodeCapabilities",
        "responses": { "200": { "description": "Launcher platform capabilities for safe node target choices", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeCapabilities" } } } } }
      }
    },
    "/api/v1/nodes/trust": {
      "post": {
        "operationId": "confirmNodeHostKey",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeTrustInput" } } } },
        "responses": { "201": { "description": "Previously probed host key pinned to the profile", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeProbeResult" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/nodes/inspect": {
      "post": {
        "operationId": "inspectNode",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeInspectionInput" } } } },
        "responses": { "200": { "description": "Read-only node report and explainable capacity/install assessment", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/NodeInspectionResult" } } } }, "409": { "$ref": "#/components/responses/Conflict" } }
      }
    },
    "/api/v1/profiles": {
      "get": {
        "operationId": "listProfiles",
        "responses": {
          "200": {
            "description": "Cluster Profiles",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ClusterProfile" } }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "operationId": "createProfile",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileInput" } } }
        },
        "responses": {
          "201": {
            "description": "Cluster Profile created",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClusterProfile" } } }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/profiles/{id}": {
      "put": {
        "operationId": "updateProfile",
        "parameters": [
          { "$ref": "#/components/parameters/ProfileID" },
          { "$ref": "#/components/parameters/CSRFToken" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ProfileInput" } } }
        },
        "responses": {
          "200": {
            "description": "Cluster Profile revised",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ClusterProfile" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/profiles/{id}/journey": {
      "get": {
        "operationId": "getJourney",
        "parameters": [{ "$ref": "#/components/parameters/ProfileID" }],
        "responses": {
          "200": {
            "description": "Setup Journey",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetupJourney" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/profiles/{id}/credentials": {
      "get": {
        "operationId": "listCredentialMetadata",
        "parameters": [{ "$ref": "#/components/parameters/ProfileID" }],
        "responses": {
          "200": {
            "description": "Credential metadata without secret values",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/CredentialMetadata" } }
              }
            }
          },
          "423": { "$ref": "#/components/responses/Locked" }
        }
      }
    },
    "/api/v1/profiles/{id}/credentials/{kind}": {
      "put": {
        "operationId": "storeCredential",
        "parameters": [
          { "$ref": "#/components/parameters/ProfileID" },
          { "$ref": "#/components/parameters/CredentialKind" },
          { "$ref": "#/components/parameters/CSRFToken" }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CredentialInput" } } }
        },
        "responses": {
          "200": {
            "description": "Stored credential metadata; the value is write-only",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CredentialMetadata" } } }
          },
          "423": { "$ref": "#/components/responses/Locked" }
        }
      },
      "delete": {
        "operationId": "removeCredential",
        "parameters": [
          { "$ref": "#/components/parameters/ProfileID" },
          { "$ref": "#/components/parameters/CredentialKind" },
          { "$ref": "#/components/parameters/CSRFToken" }
        ],
        "responses": {
          "204": { "description": "Credential removed" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "423": { "$ref": "#/components/responses/Locked" }
        }
      }
    },
    "/api/v1/plans": {
      "post": {
        "operationId": "createPlan",
        "parameters": [{ "$ref": "#/components/parameters/CSRFToken" }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PlanInput" } } }
        },
        "responses": {
          "201": {
            "description": "Immutable Change Plan",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ChangePlan" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/plans/{id}/approve": {
      "post": {
        "operationId": "approvePlan",
        "parameters": [
          { "$ref": "#/components/parameters/PlanID" },
          { "$ref": "#/components/parameters/CSRFToken" }
        ],
        "responses": {
          "202": {
            "description": "Workflow Run started",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRun" } } }
          },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/runs/{id}": {
      "get": {
        "operationId": "getRun",
        "parameters": [{ "$ref": "#/components/parameters/RunID" }],
        "responses": {
          "200": {
            "description": "Workflow Run",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRun" } } }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/runs/{id}/cancel": {
      "post": {
        "operationId": "cancelRun",
        "parameters": [
          { "$ref": "#/components/parameters/RunID" },
          { "$ref": "#/components/parameters/CSRFToken" }
        ],
        "responses": {
          "202": {
            "description": "Cancellation requested",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/WorkflowRun" } } }
          },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/api/v1/events": {
      "get": {
        "operationId": "streamEvents",
        "parameters": [
          {
            "name": "profileId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "format": "int64", "minimum": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "Cursor-aware workflow event stream",
            "content": { "text/event-stream": { "schema": { "type": "string" } } }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "launcherSession": { "type": "apiKey", "in": "cookie", "name": "smallworlds_session" }
    },
    "parameters": {
      "CSRFToken": {
        "name": "X-CSRF-Token",
        "in": "header",
        "required": true,
        "schema": { "type": "string" }
      },
      "ProfileID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "PlanID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "RunID": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "CredentialKind": {
        "name": "kind",
        "in": "path",
        "required": true,
        "schema": { "type": "string", "enum": ["git-provider-token"] }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid request",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Conflict": {
        "description": "Precondition conflict",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Locked": {
        "description": "Launcher Vault is locked",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      },
      "Unavailable": {
        "description": "Platform facility is unavailable",
        "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["code"],
        "properties": { "code": { "type": "string" } }
      },
      "SessionExchange": {
        "type": "object",
        "required": ["token"],
        "properties": { "token": { "type": "string" } }
      },
      "Session": {
        "type": "object",
        "required": ["csrfToken"],
        "properties": {
          "authenticated": { "type": "boolean" },
          "csrfToken": { "type": "string" }
        }
      },
      "VaultStatus": {
        "type": "object",
        "required": ["state", "osCredentialStoreAvailable", "passphraseFallbackAvailable"],
        "properties": {
          "state": { "type": "string", "enum": ["locked", "unlocked"] },
          "osCredentialStoreAvailable": { "type": "boolean" },
          "passphraseFallbackAvailable": { "type": "boolean" },
          "unlockMethod": { "type": "string", "enum": ["operating-system", "passphrase"] }
        }
      },
      "VaultUnlockInput": {
        "type": "object",
        "required": ["method"],
        "properties": {
          "method": { "type": "string", "enum": ["operating-system", "passphrase"] },
          "passphrase": { "type": "string", "format": "password", "writeOnly": true, "minLength": 12 }
        }
      },
      "CredentialInput": {
        "type": "object",
        "required": ["value", "expiresAt"],
        "properties": {
          "value": { "type": "string", "format": "password", "writeOnly": true, "minLength": 1 },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      },
      "CredentialMetadata": {
        "type": "object",
        "required": ["kind", "present", "source", "expiresAt", "rotationStatus"],
        "properties": {
          "kind": { "type": "string" },
          "present": { "type": "boolean" },
          "source": { "type": "string" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "rotationStatus": { "type": "string", "enum": ["current", "due-soon", "expired"] }
        }
      },
      "RecoveryBundleExportInput": {
        "type": "object",
        "required": ["profileId"],
        "properties": {
          "profileId": { "type": "string" },
          "passphrase": { "type": "string", "format": "password", "writeOnly": true, "minLength": 12 },
          "recipients": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        },
        "description": "Provide exactly one of passphrase or public age recipients."
      },
      "RecoveryBundleOpenInput": {
        "type": "object",
        "required": ["bundle"],
        "properties": {
          "bundle": { "type": "string", "format": "byte", "writeOnly": true },
          "passphrase": { "type": "string", "format": "password", "writeOnly": true, "minLength": 12 },
          "identity": { "type": "string", "format": "password", "writeOnly": true }
        },
        "description": "Provide exactly one of passphrase or private age identity."
      },
      "RecoveryBundleImportInput": {
        "allOf": [
          { "$ref": "#/components/schemas/RecoveryBundleOpenInput" },
          {
            "type": "object",
            "required": ["expectedProfileId"],
            "properties": { "expectedProfileId": { "type": "string" } }
          }
        ]
      },
      "RecoveryBundlePreview": {
        "type": "object",
        "required": ["format", "version", "profile"],
        "properties": {
          "format": { "type": "string", "const": "smallworlds-recovery-bundle" },
          "version": { "type": "integer", "const": 1 },
          "profile": {
            "type": "object",
            "required": ["id", "name", "deploymentMode"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "deploymentMode": { "type": "string", "enum": ["hetzner", "local-lan", "local-public"] }
            }
          }
        }
      },
      "RecoveryBundleImportResult": {
        "type": "object",
        "required": ["profile"],
        "properties": {
          "profile": {
            "type": "object",
            "required": ["id", "name"],
            "properties": { "id": { "type": "string" }, "name": { "type": "string" } }
          }
        }
      },
      "CapabilityCatalog": { "type": "object", "required": ["version", "capabilities"], "properties": { "version": { "type": "integer", "const": 1 }, "capabilities": { "type": "array", "items": { "$ref": "#/components/schemas/CapabilityEntry" } } } },
      "CapabilityEntry": { "type": "object", "required": ["id", "displayKey", "category", "required", "dependencies", "supportedDeploymentModes", "resources", "exposure", "protection", "observer"], "properties": { "id": { "type": "string" }, "displayKey": { "type": "string" }, "category": { "type": "string", "enum": ["platform-service", "community-application"] }, "required": { "type": "boolean" }, "dependencies": { "type": "array", "items": { "type": "string" } }, "supportedDeploymentModes": { "type": "array", "items": { "type": "string", "enum": ["hetzner", "local-lan", "local-public"] } }, "resources": { "$ref": "#/components/schemas/CapabilityResources" }, "exposure": { "type": "string" }, "protection": { "type": "string" }, "observer": { "type": "string" } } },
      "CapabilityResources": { "type": "object", "required": ["memoryMi", "storageGi"], "properties": { "memoryMi": { "type": "integer", "minimum": 0 }, "storageGi": { "type": "integer", "minimum": 0 } } },
      "CapabilityPlanInput": { "type": "object", "required": ["profileId", "mode", "release", "repositoryUrl", "domain"], "properties": { "profileId": { "type": "string" }, "mode": { "type": "string", "enum": ["minimal", "collaboration", "full", "custom"] }, "communityIds": { "type": "array", "items": { "type": "string" } }, "release": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+" }, "repositoryUrl": { "type": "string", "format": "uri" }, "domain": { "type": "string" } } },
      "CapabilityPlanResult": { "type": "object", "required": ["plan", "overlay"], "properties": { "plan": { "$ref": "#/components/schemas/ChangePlan" }, "overlay": { "$ref": "#/components/schemas/RenderedOverlay" } } },
      "RenderedOverlay": { "type": "object", "required": ["files", "diff", "assessment"], "properties": { "files": { "type": "object", "additionalProperties": { "type": "string" } }, "diff": { "type": "string" }, "assessment": { "$ref": "#/components/schemas/CapabilityAssessment" } } },
      "CapabilityAssessment": { "type": "object", "required": ["selected", "communityIds", "resources", "exposure", "protection"], "properties": { "selected": { "type": "object", "additionalProperties": { "type": "boolean" } }, "communityIds": { "type": "array", "items": { "type": "string" } }, "resources": { "$ref": "#/components/schemas/CapabilityResources" }, "exposure": { "type": "array", "items": { "type": "string" } }, "protection": { "type": "array", "items": { "type": "string" } } } },
      "GitHubTokenInput": { "type": "object", "required": ["profileId", "token", "authority"], "properties": { "profileId": { "type": "string" }, "token": { "type": "string", "format": "password", "writeOnly": true }, "authority": { "type": "string", "enum": ["creation", "ongoing"] } } },
      "GitHubTokenStatus": { "type": "object", "required": ["owner", "authority", "stored"], "properties": { "owner": { "type": "string" }, "expiresAt": { "type": "string", "format": "date-time" }, "authority": { "type": "string", "enum": ["creation", "ongoing"] }, "stored": { "type": "boolean" } } },
      "GitHubOverlayEstablishInput": { "allOf": [{ "$ref": "#/components/schemas/CapabilityPlanInput" }, { "type": "object", "required": ["planId", "repositoryName"], "properties": { "planId": { "type": "string" }, "repositoryName": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" } } }] },
      "GenericGitCredentialInput": { "type": "object", "required": ["profileId", "repositoryUrl", "username", "token"], "properties": { "profileId": { "type": "string" }, "repositoryUrl": { "type": "string", "format": "uri", "pattern": "^https://" }, "username": { "type": "string", "writeOnly": true }, "token": { "type": "string", "format": "password", "writeOnly": true } } },
      "GenericGitCredentialStatus": { "type": "object", "required": ["repositoryUrl", "stored"], "properties": { "repositoryUrl": { "type": "string", "format": "uri" }, "stored": { "type": "boolean" } } },
      "GenericGitOverlayEstablishInput": { "allOf": [{ "$ref": "#/components/schemas/CapabilityPlanInput" }, { "type": "object", "required": ["planId"], "properties": { "planId": { "type": "string" } } }] },
      "GenericGitProposal": { "type": "object", "required": ["branch", "commit", "mergeInstructionKey"], "properties": { "branch": { "type": "string", "pattern": "^smallworlds/proposal-" }, "commit": { "type": "string" }, "mergeInstructionKey": { "type": "string", "const": "generic_git_manual_merge" } } },
      "BootstrapAssetStatus": { "type": "object", "required": ["id", "release", "destination", "sha256", "state", "bytes"], "properties": { "id": { "type": "string" }, "release": { "type": "string" }, "destination": { "type": "string" }, "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "state": { "type": "string", "enum": ["missing", "partial", "ready"] }, "bytes": { "type": "integer", "minimum": 0 } } },
      "BootstrapAssetRequirements": { "type": "object", "required": ["release", "assets", "offlineBundleAvailability"], "properties": { "release": { "type": "string" }, "assets": { "type": "array", "items": { "$ref": "#/components/schemas/BootstrapAssetStatus" } }, "offlineBundleAvailability": { "type": "string", "const": "future" } } },
      "BootstrapAssetAcquireInput": { "type": "object", "required": ["release"], "properties": { "release": { "type": "string", "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+" } } },
      "NodeTarget": { "type": "object", "required": ["kind"], "properties": { "kind": { "type": "string", "enum": ["remote", "same-host"] }, "host": { "type": "string" }, "port": { "type": "integer", "minimum": 1, "maximum": 65535 }, "username": { "type": "string" } } },
      "NodeCapabilities": { "type": "object", "required": ["sameHostSupported"], "properties": { "sameHostSupported": { "type": "boolean" } } },
      "NodeProbeInput": { "type": "object", "required": ["profileId", "target"], "properties": { "profileId": { "type": "string" }, "target": { "$ref": "#/components/schemas/NodeTarget" } } },
      "NodeProbeResult": { "type": "object", "required": ["target", "fingerprint"], "properties": { "target": { "$ref": "#/components/schemas/NodeTarget" }, "fingerprint": { "type": "string", "pattern": "^SHA256:" }, "requiresConfirmation": { "type": "boolean" } } },
      "NodeTrustInput": { "allOf": [{ "$ref": "#/components/schemas/NodeProbeInput" }, { "type": "object", "required": ["fingerprint", "confirmed"], "properties": { "fingerprint": { "type": "string", "pattern": "^SHA256:" }, "confirmed": { "type": "boolean", "const": true } } }] },
      "NodeAuthentication": { "type": "object", "required": ["kind"], "properties": { "kind": { "type": "string", "enum": ["agent", "private-key", "password"] }, "password": { "type": "string", "format": "password", "writeOnly": true }, "privateKey": { "type": "string", "format": "password", "writeOnly": true }, "keyPassphrase": { "type": "string", "format": "password", "writeOnly": true }, "sudoPassword": { "type": "string", "format": "password", "writeOnly": true } } },
      "NodeInspectionInput": { "type": "object", "required": ["profileId", "target", "authentication"], "properties": { "profileId": { "type": "string" }, "target": { "$ref": "#/components/schemas/NodeTarget" }, "authentication": { "$ref": "#/components/schemas/NodeAuthentication" } } },
      "NodeAssessment": { "type": "object", "required": ["ready", "resumable", "blockers"], "properties": { "ready": { "type": "boolean" }, "resumable": { "type": "boolean" }, "blockers": { "type": "array", "items": { "type": "object", "required": ["code"], "properties": { "code": { "type": "string" } } } } } },
      "NodeCapacity": { "type": "object", "required": ["cpuCores", "memoryMi", "diskGi"], "properties": { "cpuCores": { "type": "integer", "minimum": 0 }, "memoryMi": { "type": "integer", "minimum": 0 }, "diskGi": { "type": "integer", "minimum": 0 } } },
      "NodeReport": { "type": "object", "required": ["operatingSystem", "architecture", "systemd", "capacity", "ports", "kernelReady", "privilege", "installation"], "properties": { "operatingSystem": { "type": "string" }, "architecture": { "type": "string" }, "systemd": { "type": "boolean" }, "capacity": { "$ref": "#/components/schemas/NodeCapacity" }, "ports": { "type": "array", "items": { "type": "integer" } }, "kernelReady": { "type": "boolean" }, "privilege": { "type": "string" }, "installation": { "type": "object" } } },
      "NodeInspectionResult": { "type": "object", "required": ["target", "report", "assessment"], "properties": { "target": { "$ref": "#/components/schemas/NodeTarget" }, "report": { "$ref": "#/components/schemas/NodeReport" }, "assessment": { "$ref": "#/components/schemas/NodeAssessment" } } },
      "OverlayIdentity": { "type": "object", "required": ["profileId", "provider", "repository", "repositoryUrl", "release", "commit", "recordedAt"], "properties": { "profileId": { "type": "string" }, "provider": { "type": "string", "enum": ["github", "generic-https"] }, "repository": { "type": "string" }, "repositoryUrl": { "type": "string", "format": "uri" }, "release": { "type": "string" }, "commit": { "type": "string" }, "recordedAt": { "type": "string", "format": "date-time" } } },
      "ProfileInput": {
        "type": "object",
        "required": ["name", "language", "deploymentMode"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 120 },
          "language": { "type": "string", "enum": ["en", "de"] },
          "deploymentMode": { "type": "string", "enum": ["hetzner", "local-lan", "local-public"] }
        }
      },
      "ClusterProfile": {
        "allOf": [
          { "$ref": "#/components/schemas/ProfileInput" },
          {
            "type": "object",
            "required": ["id", "revision", "createdAt"],
            "properties": {
              "id": { "type": "string" },
              "revision": { "type": "integer", "format": "int64" },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        ]
      },
      "JourneyTask": {
        "type": "object",
        "required": ["id", "state", "recommended", "evidenceState"],
        "properties": {
          "id": { "type": "string" },
          "state": { "type": "string", "enum": ["ready", "running", "completed"] },
          "recommended": { "type": "boolean" },
          "evidenceState": { "type": "string", "enum": ["missing", "current", "stale"] },
          "evidenceCode": { "type": "string" },
          "observedAt": { "type": "string", "format": "date-time" }
        }
      },
      "SetupJourney": {
        "type": "object",
        "required": ["profileId", "tasks"],
        "properties": {
          "profileId": { "type": "string" },
          "tasks": { "type": "array", "items": { "$ref": "#/components/schemas/JourneyTask" } }
        }
      },
      "PlanInput": {
        "type": "object",
        "required": ["profileId", "intent"],
        "properties": {
          "profileId": { "type": "string" },
          "intent": { "type": "string", "enum": ["VerifyLauncher"] }
        }
      },
      "PlanEffect": {
        "type": "object",
        "required": ["code", "messageKey"],
        "properties": {
          "code": { "type": "string" },
          "messageKey": { "type": "string" }
        }
      },
      "ChangePlan": {
        "type": "object",
        "required": ["id", "profileId", "intent", "digest", "status", "preconditions", "effects", "risks", "createdAt"],
        "properties": {
          "id": { "type": "string" },
          "profileId": { "type": "string" },
          "intent": { "type": "string" },
          "digest": { "type": "string" },
          "status": { "type": "string" },
          "preconditions": {
            "type": "object",
            "required": ["profileRevision"],
            "properties": { "profileRevision": { "type": "integer", "format": "int64" } }
          },
          "effects": { "type": "array", "items": { "$ref": "#/components/schemas/PlanEffect" } },
          "risks": { "type": "array", "items": { "$ref": "#/components/schemas/PlanEffect" } },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "WorkflowRun": {
        "type": "object",
        "required": ["id", "planId", "profileId", "state", "currentCheckpoint", "cancellationState", "verification", "createdAt", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "planId": { "type": "string" },
          "profileId": { "type": "string" },
          "state": { "type": "string", "enum": ["running", "verified", "cancelled", "failed"] },
          "currentCheckpoint": { "type": "string" },
          "cancellationState": { "type": "string", "enum": ["not-requested", "requested", "completed"] },
          "verification": {
            "type": "object",
            "required": ["code", "observedAt"],
            "properties": {
              "code": { "type": "string" },
              "observedAt": { "type": "string", "format": "date-time" }
            }
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
